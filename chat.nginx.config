server {
    	server_name chat.keypartners24.ru;
    	access_log /var/log/nginx/chat-access.log;
    	error_log /var/log/nginx/chat-error.log;
location / {
        try_files $uri $uri/ = 404;
    }
	index index.html;
	root /usr/local/projects/chat-server/web;
location ^~ /chat  {
    	proxy_pass http://127.0.0.1:8080; # you golang applecation port
    	proxy_set_header Host $host;
    	proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    	proxy_set_header X-Real-IP $remote_addr;
	proxy_set_header Content-Type $content_type;
	proxy_set_header X-Forwarded-Proto $scheme;

	# Для WebSocket (если нужно для чата)
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        # Таймауты для длительных соединений
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;

        # Отключаем буферизацию для WebSocket
        proxy_buffering off;
    }


    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/chat.keypartners24.ru/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/chat.keypartners24.ru/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot

}
server {
    if ($host = chat.keypartners24.ru) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


	listen 80;
    	server_name chat.keypartners24.ru;
    return 404; # managed by Certbot


}
